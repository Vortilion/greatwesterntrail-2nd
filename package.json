{
  "name": "gwt-2nd-randomizer",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "copy-index-to-404": "cp dist/gwt-2nd_randomizer/browser/index.html dist/gwt-2nd_randomizer/browser/404.html",
    "build:prod": "ng build --configuration production --base-href=https://vortilion.github.io/greatwesterntrail-2nd/ && npm run copy-index-to-404",
